+class FutureSeedMixer(nn.Module):
+    def __init__(self, hidden_size: int, rms_norm_eps: float, scale: float, gate_bias: float) -> None:
+        super().__init__()
+        self.future_seed_scale = float(scale)
+        self.norm_eps = float(rms_norm_eps)
+        self.gate_logit = nn.Parameter(torch.tensor(float(gate_bias)))
+        self.proj = CastedLinear(hidden_size, hidden_size, bias=False)
+        with torch.no_grad():
+            self.proj.weight.zero_()
+            idx = torch.arange(hidden_size)
+            self.proj.weight[idx, idx] = 1.0
+
+    def forward(self, target: torch.Tensor, seed: torch.Tensor) -> torch.Tensor:
+        scale = float(self.future_seed_scale)
+        if scale == 0.0:
+            return target
+        seeded = self.proj(rms_norm(seed, variance_epsilon=self.norm_eps)).to(target.dtype)
+        gate = torch.sigmoid(self.gate_logit.to(torch.float32)).to(target.dtype) * scale
+        return target + gate * seeded
+
+
+class FeatureNoiseBuffer(nn.Module):
+    def __init__(self, hidden_size: int, max_size: int, max_add: int) -> None:
+        super().__init__()
+        self.hidden_size = int(hidden_size)
+        self.max_size = max(0, int(max_size))
+        self.max_add = max(0, int(max_add))
+        self.register_buffer("features", torch.empty(0, self.hidden_size), persistent=False)
+        self.register_buffer("feature_count", torch.zeros((), dtype=torch.long), persistent=False)
+        self.register_buffer("feature_ptr", torch.zeros((), dtype=torch.long), persistent=False)
+
+    def _ensure_storage(self, reference: torch.Tensor) -> bool:
+        if self.max_size <= 1:
+            return False
+        if self.feature_count.device != reference.device:
+            self.feature_count = self.feature_count.to(reference.device)
+            self.feature_ptr = self.feature_ptr.to(reference.device)
+        expected_shape = (self.max_size, self.hidden_size)
+        storage_mismatch = (
+            self.features.device != reference.device
+            or self.features.dtype != reference.dtype
+            or tuple(self.features.shape) != expected_shape
+        )
+        if storage_mismatch:
+            self.features = torch.empty(expected_shape, dtype=reference.dtype, device=reference.device)
+            self.feature_count.zero_()
+            self.feature_ptr.zero_()
+        return True
+
+    @_disable_torch_compile
+    @torch.no_grad()
+    def add(self, features: torch.Tensor) -> None:
+        if not self._ensure_storage(features):
+            return
+        flat = features.detach().reshape(-1, self.hidden_size)
+        if flat.shape[0] == 0:
+            return
+        add_count = flat.shape[0] if self.max_add == 0 else min(self.max_add, flat.shape[0])
+        if flat.shape[0] > add_count:
+            flat = flat.index_select(0, torch.randint(flat.shape[0], (add_count,), device=flat.device))
+        if flat.shape[0] > self.max_size:
+            flat = flat[-self.max_size :]
+
+        n = int(flat.shape[0])
+        ptr = int(self.feature_ptr.item())
+        first = min(n, self.max_size - ptr)
+        self.features[ptr : ptr + first].copy_(flat[:first])
+        if first < n:
+            self.features[: n - first].copy_(flat[first:])
+        self.feature_ptr.fill_((ptr + n) % self.max_size)
+        self.feature_count.fill_(min(self.max_size, int(self.feature_count.item()) + n))
+
+    @_disable_torch_compile
+    @torch.no_grad()
+    def sample(self, reference: torch.Tensor) -> Optional[torch.Tensor]:
+        if not self._ensure_storage(reference):
+            return None
+        count = int(self.feature_count.item())
+        if count < 2:
+            return None
+        out_shape = reference.shape[:-1]
+        idx_a = torch.randint(count, out_shape, device=reference.device)
+        idx_b = (idx_a + 1 + torch.randint(count - 1, out_shape, device=reference.device)) % count
+        noise = self.features[idx_a] - self.features[idx_b]
+        noise_fp32 = noise.to(torch.float32)
+        noise_rms = noise_fp32.square().mean(dim=-1, keepdim=True).sqrt().clamp_min(1e-6)
+        ref_rms = (
+            reference.detach()
+            .to(torch.float32)
+            .square()
+            .mean(dim=-1, keepdim=True)
+            .sqrt()
+            .clamp_min(1e-6)
+        )
+        return (noise_fp32 * (ref_rms / noise_rms)).to(reference.dtype)
+
